

func add(a int, b int) int {
    return a + b
}

func divide(a float, b float) float {
    return a / b
}

func main() {
    var flag bool
    var msg string
    var e err

    x := 10
    y := 3.14
    flag = true
    msg = "hello"

    x = x + 5 * 2
    x = (x + 1) * 3

    x++
    y--

    x, y = 1, 2.0

    result := add(x, 10)

    if x > 0 {
        print()
    }

    if x == result {
        print()
    } else {
        print()
    }

    if false {
        print()
    }

    for true {
        break
    }

    for x >= 0 {
        if x == 50 {
            continue
        }
        x--
    }

    e = error("something went wrong")

    return
}

func multiReturn(a int, b int) (int, int) {
    return a + b, a - b
}